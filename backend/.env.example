# Copiá este archivo como ".env" (sin el ".example") y completá tus propios valores.
# El archivo ".env" NUNCA se sube a GitHub (ver .gitignore).

PORT=3000

# Cadena secreta y larga, inventada por vos, para "salar" el hash de las IPs.
IP_SALT=cambiala-por-algo-largo-y-aleatorio-12345

# Dominios que pueden llamar a esta API, separados por coma.
# En local: http://127.0.0.1:5500 (si usás la extensión Live Server de VS Code)
# En producción: la URL real de tu frontend, ej: https://tu-usuario.github.io
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Clave secreta inventada por vos para poder ver todos los datos guardados
# (gamertags, votos, opiniones) en https://tu-backend/api/admin/export?key=...
# Si la dejás vacía o no la configurás, esa ruta queda bloqueada por completo.
ADMIN_KEY=inventa-otra-clave-larga-y-dificil-de-adivinar

# Clave de cifrado de la IP (AES-256-GCM). A diferencia de las anteriores,
# esta NO la inventás a mano: tiene que ser exactamente 32 bytes en formato
# hexadecimal (64 caracteres). Para generarla, corré este comando una vez
# en tu terminal (con Node.js instalado) y pegá el resultado acá:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_ENCRYPTION_KEY=
