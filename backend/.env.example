# Copiá este archivo como ".env" (sin el ".example") y completá tus propios valores.
# El archivo ".env" NUNCA se sube a GitHub (ver .gitignore).

PORT=3000

# Cadena secreta y larga, inventada por vos, para "salar" el hash de las IPs.
IP_SALT=cambiala-por-algo-largo-y-aleatorio-12345

# Dominios que pueden llamar a esta API, separados por coma.
# En local: http://127.0.0.1:5500 (si usás la extensión Live Server de VS Code)
# En producción: la URL real de tu frontend, ej: https://tu-usuario.github.io
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
